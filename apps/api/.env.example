# Server
NODE_ENV=production
PORT=4000

# Database  (Railway PostgreSQL / Neon / Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis  (Railway Redis / Upstash — optional but recommended)
REDIS_URL="redis://default:password@host:6379"

# JWT — generate strong secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret

# Shared secret for internal Next.js → API calls (e.g. token refresh)
# Must match INTERNAL_SECRET in the web app's env
INTERNAL_SECRET=replace-with-strong-secret

# Frontend URL (your Vercel deployment URL)
CLIENT_ORIGIN=https://flexflow-one.vercel.app

# Additional allowed CORS origins, comma-separated (optional)
# ADDITIONAL_ORIGINS="https://custom-domain.com"

# Resend email (optional — invites are created but not emailed without this)
RESEND_API_KEY=re_your_resend_api_key
